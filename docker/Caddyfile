# Global options — must be first
{
	on_demand_tls {
		ask http://localhost:3001/api/health/domain-check
	}
}

# Shared routing logic used by both site blocks
(common) {
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "camera=(), microphone=(), geolocation=()"
	}

	handle /api/* {
		reverse_proxy 127.0.0.1:3001 {
			# Rewrite Origin to the main domain so Better Auth trusted origins check
			# always passes, regardless of which custom domain the request came from.
			header_up Origin "{$WEB_URL}"
		}
		header Cache-Control "no-store, no-cache, must-revalidate"
	}

	handle {
		reverse_proxy 127.0.0.1:3000
	}
}

# :8080 — plain HTTP, for traffic proxied by Coolify/Cloudflare (TLS terminated upstream)
:8080 {
	import common
}

# :443 — HTTPS with on-demand TLS for custom org domains connecting directly
:443 {
	tls {
		on_demand
	}

	import common
}
