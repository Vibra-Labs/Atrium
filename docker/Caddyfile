# NOTE: The on_demand_tls block enables automatic SSL for custom domains.
# This is intended for hosted deployments (atriumapp.vibralabs.co).
# Self-hosters: remove the on_demand_tls block and "tls { on_demand }" directive,
# and change ":443, :8080" back to ":8080".
{
	on_demand_tls {
		ask http://localhost:3001/api/health/domain-check
	}
}

:443, :8080 {
	tls {
		on_demand
	}

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "camera=(), microphone=(), geolocation=()"
	}

	handle /api/* {
		reverse_proxy 127.0.0.1:3001 {
			# Rewrite Origin to the main domain so Better Auth trusted origins check
			# always passes, regardless of which custom domain the request came from.
			header_up Origin "{$WEB_URL}"
		}
		header Cache-Control "no-store, no-cache, must-revalidate"
	}

	handle {
		reverse_proxy 127.0.0.1:3000
	}
}
